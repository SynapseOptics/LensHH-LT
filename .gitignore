bin/
obj/
*.user
*.suo
.vs/
*.DotSettings.user
TestResults/

# Microsoft Office lock files (created when a document is open).
~$*

# Core PDB must never ship in the public tree (symbol tables are
# source-equivalent). The release DLL ships without debug symbols.
engine/*.pdb

# Installer build outputs
installer/Output/
installer/AppImage/
installer/appimagetool-*.AppImage

# Bundled Microsoft VC++ Redistributable (downloaded by build-installer.bat
# from https://aka.ms/vs/17/release/vc_redist.x64.exe — ~25 MB; chain-installed
# during setup if not already present).
installer/redist/

# rcodesign (apple-codesign) — Mach-O signing from Windows; auto-downloaded
# by installer/build-mac-package.ps1 from the apple-platform-rs GitHub
# releases (SHA256-verified). ~12 MB binary, not committed.
installer/tools/rcodesign/

# macOS package staging/output (built by installer/build-mac-package.ps1)
installer/osx-test/
installer/osx-dist/

# Documentation PDF build — all outputs (PDF + intermediate HTML +
# node_modules) are regenerated from docs/*.md by
# installer/build-installer.bat on each installer build.
docs/build/node_modules/
docs/build/package-lock.json
docs/build/LensHH-LT-docs.html
docs/LensHH-LT-UserGuide.pdf
docs/LensHH-LT-UserGuide-*.pdf
docs/html/

# Pre-cropped originals of User Guide screenshots — the resized
# versions in docs/images/ are what ship.
docs/images/_originals/

# Runtime logs (per-run noise; never ship).
logs/

# User-generated filter catalogs from local testing. The
# manufacturer AGFs in catalogs/Glass/ are tracked; everything in
# FilteredGlassCatalogues is regenerated locally via Optimization
# → Create Glass Catalogue — except CoreSet28.AGF, which is the
# default filtered catalog the SPC case study and shipped samples
# refer to and is bundled into the installer.
catalogs/FilteredGlassCatalogues/*
!catalogs/FilteredGlassCatalogues/CoreSet28.AGF
!catalogs/FilteredGlassCatalogues/StockGlassesUV.AGF
!catalogs/FilteredGlassCatalogues/StockGlassesVisible.AGF

# Vendor optical files (raw stock-lens prescriptions scraped or extracted
# from vendor distributions). Large (~540 MB) and re-derivable: Edmund
# .zmx come from the scraper; Thorlabs from THORLABS_*.ZMF via
# catalogs/scripts/Extract-ZmfCatalog.ps1. Our derived .lhlt ARE tracked.
catalogs/Lenses/**/*.zmx
catalogs/Lenses/**/*.zar
catalogs/Lenses/**/*.seq
catalogs/Lenses/**/*.ZMF
catalogs/Lenses/**/*.zip
catalogs/Lenses/**/*.dat
catalogs/Lenses/**/*.DAT
catalogs/Lenses/**/*.xlsx
catalogs/Lenses/ThorLabs/zemaxcatalog/

# Avalonia XAML compiler build cache (not source)
**/.avalonia-build-tasks/
