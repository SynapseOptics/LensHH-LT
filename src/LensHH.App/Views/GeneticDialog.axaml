<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LensHH.App.ViewModels"
        x:Class="LensHH.App.Views.GeneticDialog"
        x:DataType="vm:GeneticDialogViewModel"
        Title="Genetic Optimization"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="750" MinHeight="500">

  <DockPanel Margin="12">

    <!-- Bottom Buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
      <Button Content="OK — Accept Results" Click="OK_Click" Width="180"
              IsEnabled="{Binding IsComplete}" FontWeight="SemiBold" />
      <Button Content="Cancel — Revert" Click="Cancel_Click" Width="150" IsCancel="True" />
    </StackPanel>

    <!-- Settings -->
    <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="Auto,6,60,16,Auto,6,60,16,Auto,6,50,16,Auto,6,50,*,Auto"
            RowDefinitions="Auto,6,Auto">
        <!-- Row 0 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Population:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding PopulationSize, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />
        <TextBlock Grid.Row="0" Grid.Column="4" Text="Generations:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="6" Text="{Binding Generations, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />
        <TextBlock Grid.Row="0" Grid.Column="8" Text="Mut %:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="10" Text="{Binding MutationRate, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />
        <TextBlock Grid.Row="0" Grid.Column="12" Text="Xover %:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="14" Text="{Binding CrossoverRate, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />

        <!-- Row 1 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Elite:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding EliteCount, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />
        <TextBlock Grid.Row="2" Grid.Column="4" Text="LM Top:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding LmTopCount, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />
        <TextBlock Grid.Row="2" Grid.Column="8" Text="LM Iter:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="10" Text="{Binding LmIterations, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}" />

        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="16" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <Button Content="Start" Command="{Binding StartOptimizationCommand}"
                  IsEnabled="{Binding !IsRunning}" Width="80" />
          <Button Content="Stop" Command="{Binding StopOptimizationCommand}"
                  IsEnabled="{Binding IsRunning}" Width="80" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Status -->
    <Border DockPanel.Dock="Top" Background="#F5F5F5" CornerRadius="4"
            Padding="12,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="*,Auto,20,Auto" RowDefinitions="Auto,4,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding StatusText}"
                   FontWeight="SemiBold" FontSize="14" />
        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ElapsedText}" FontSize="13" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MeritText}"
                   FontSize="13" FontFamily="Consolas" />
        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Spacing="16">
          <TextBlock Text="{Binding InitialMeritText, StringFormat='Initial: {0}'}"
                     FontSize="12" Foreground="Gray" />
          <TextBlock Text="{Binding GeneticMeritText, StringFormat='Genetic: {0}'}"
                     FontSize="12" Foreground="Orange" />
          <TextBlock Text="{Binding BestMeritText, StringFormat='Best: {0}'}"
                     FontSize="12" Foreground="Green" FontWeight="SemiBold" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Variable table -->
    <DataGrid ItemsSource="{Binding VariableRows}"
              AutoGenerateColumns="False" CanUserSortColumns="False"
              GridLinesVisibility="All" IsReadOnly="True"
              FontSize="13" FontFamily="Consolas">
      <DataGrid.Styles>
        <Style Selector="DataGridColumnHeader">
          <Setter Property="FontWeight" Value="Bold" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="Padding" Value="6,4" />
          <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
      </DataGrid.Styles>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Variable" Binding="{Binding Description}" Width="160" />
        <DataGridTextColumn Header="Start" Binding="{Binding StartValue}" Width="140" />
        <DataGridTextColumn Header="Best" Binding="{Binding CurrentValue}" Width="140" />
        <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="130" />
      </DataGrid.Columns>
    </DataGrid>

  </DockPanel>
</Window>
