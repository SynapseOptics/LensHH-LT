<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LensHH.App.ViewModels"
        x:Class="LensHH.App.Views.FieldEditorDialog"
        x:DataType="vm:FieldEditorViewModel"
        Title="Field Editor"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="480" Height="350"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <DockPanel Margin="8">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="Add" Command="{Binding AddCommand}" Width="70" />
      <Button Content="Insert" Command="{Binding InsertCommand}" Width="70" />
      <Button Content="Remove" Command="{Binding RemoveCommand}" Width="70" />
      <Button Content="OK" Click="OK_Click" Width="70" />
      <Button Content="Cancel" Click="Cancel_Click" Width="70" IsCancel="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom"
               Text="{Binding StatusText}"
               Foreground="#B00020"
               TextWrapping="Wrap"
               Margin="0,4,0,0"
               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <DataGrid x:Name="FieldGrid"
              ItemsSource="{Binding Fields}"
              SelectedItem="{Binding SelectedField}"
              AutoGenerateColumns="False"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              IsReadOnly="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Field No" Binding="{Binding Number}" IsReadOnly="True" Width="70" />
        <DataGridTemplateColumn Header="{Binding $parent[Window].DataContext.FieldUnit, FallbackValue='Field Y'}" Width="160">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding YText}" Margin="4,0" VerticalAlignment="Center"
                         ToolTip.Tip="Single-field designs require Y = 0. Add another field to edit." />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
          <DataGridTemplateColumn.CellEditingTemplate>
            <DataTemplate>
              <TextBox Text="{Binding YText, Mode=TwoWay}" IsReadOnly="{Binding IsYLockedToZero}" />
            </DataTemplate>
          </DataGridTemplateColumn.CellEditingTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Weight" Binding="{Binding WeightText}" Width="80" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
