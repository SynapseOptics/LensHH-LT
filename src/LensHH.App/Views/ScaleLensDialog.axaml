<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LensHH.App.ViewModels"
        x:Class="LensHH.App.Views.ScaleLensDialog"
        x:DataType="vm:ScaleLensViewModel"
        Title="Scale Lens"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="320" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <StackPanel Margin="16" Spacing="12">

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Scale Factor:" VerticalAlignment="Center" />
      <TextBox Text="{Binding ScaleFactor, UpdateSourceTrigger=LostFocus}" Width="120" />
    </StackPanel>

    <TextBlock Text="Scales radii, thicknesses, asphere coefficients, EPD, and fixed semi-diameters."
               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="OK" Click="OK_Click" Width="70" />
      <Button Content="Cancel" Click="Cancel_Click" Width="70" IsCancel="True" />
    </StackPanel>

  </StackPanel>
</Window>
