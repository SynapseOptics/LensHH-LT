      <!-- Relative Illumination Tab (visible on demand via Analysis menu) -->
      <TabItem Header="Rel. Illumination" IsVisible="{Binding RelativeIllumination.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <Button Content="Compute" Command="{Binding RelativeIllumination.ComputeCommand}" Width="80" />
              <TextBlock Text="Field pts:" VerticalAlignment="Center" />
              <TextBox Text="{Binding RelativeIllumination.NumFieldPoints}" Width="50"
                       ToolTip.Tip="Number of field points sampled. More = smoother curve, slower." />
              <TextBlock Text="Pupil samples:" VerticalAlignment="Center" />
              <TextBox Text="{Binding RelativeIllumination.NumPupilRays}" Width="50"
                       ToolTip.Tip="Pupil-boundary directions sampled per field point. More = smoother / better vignetting fidelity, slower." />
              <Button Content="Export Text..." Command="{Binding RelativeIllumination.ExportTextCommand}" Width="100"
                      IsEnabled="{Binding !RelativeIllumination.IsOnAxisOnly}" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="RelativeIllumination" Width="90" FontSize="11" />
              <Button Content="Show Table" Click="RelIllumShowTable_Click" Width="80" FontSize="11" />
              <Button Content="Close Tab" Click="CloseRelativeIlluminationTab_Click" Width="70" FontSize="11" />
