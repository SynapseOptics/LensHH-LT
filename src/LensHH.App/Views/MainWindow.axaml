        </Grid>
      </TabItem>

      <TabItem Header="OPD Fan" IsVisible="{Binding OpdFan.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <TextBlock Text="Points:" VerticalAlignment="Center" />
              <TextBox Text="{Binding OpdFan.NumPoints, UpdateSourceTrigger=LostFocus}" Width="50" />
              <Button Content="Compute" Command="{Binding OpdFan.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding OpdFan.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="OpdFan" Width="90" FontSize="11" />
              <Button Content="Close Tab" Click="CloseOpdFanTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding OpdFan.OpdFanImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding OpdFan.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Wavefront Map" IsVisible="{Binding WavefrontMap.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <TextBlock Text="Grid:" VerticalAlignment="Center" />
              <ComboBox SelectedIndex="1" SelectionChanged="WavefrontGridChanged" Width="70">
                <ComboBoxItem Content="32" />
                <ComboBoxItem Content="64" />
                <ComboBoxItem Content="128" />
                <ComboBoxItem Content="256" />
                <ComboBoxItem Content="512" />
              </ComboBox>
              <Button Content="Compute" Command="{Binding WavefrontMap.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding WavefrontMap.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="WavefrontMap" Width="90" FontSize="11" />
              <Button Content="Close Tab" Click="CloseWavefrontMapTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding WavefrontMap.WavefrontImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding WavefrontMap.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Pupil Aberration" IsVisible="{Binding PupilAberrationFan.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <TextBlock Text="Points:" VerticalAlignment="Center" />
              <TextBox Text="{Binding PupilAberrationFan.NumPoints, UpdateSourceTrigger=LostFocus}" Width="50" />
              <Button Content="Compute" Command="{Binding PupilAberrationFan.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding PupilAberrationFan.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="PupilAberrationFan" Width="90" FontSize="11" />
              <Button Content="Close Tab" Click="ClosePupilAberrationFanTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding PupilAberrationFan.PlotImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding PupilAberrationFan.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Lateral Color" IsVisible="{Binding LateralColor.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <Button Content="Compute" Command="{Binding LateralColor.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding LateralColor.ExportTextCommand}" Width="100"
                      IsEnabled="{Binding !LateralColor.IsDisabled}" />
              <Button Content="Copy Table" Command="{Binding LateralColor.CopyTableToClipboardCommand}" Width="85" FontSize="11"
                      IsEnabled="{Binding !LateralColor.IsDisabled}" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="LateralColor" Width="90" FontSize="11" />
              <Button Content="Show Table" Click="LateralColorShowTable_Click" Width="80" FontSize="11" />
              <Button Content="Close Tab" Click="CloseLateralColorTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding LateralColor.PlotImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding LateralColor.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <Border Background="#F0F0F0" IsVisible="{Binding LateralColor.IsDisabled}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Requires multiple wavelengths and off-axis fields."
                       FontSize="16" Foreground="#888"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Chromatic Focal Shift" IsVisible="{Binding ChromaticFocalShift.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <Button Content="Compute" Command="{Binding ChromaticFocalShift.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding ChromaticFocalShift.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="ChromaticFocalShift" Width="90" FontSize="11" />
              <Button Content="Show Table" Click="ChromaticFocalShiftShowTable_Click" Width="80" FontSize="11" />
              <Button Content="Close Tab" Click="CloseChromFocalShiftTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding ChromaticFocalShift.PlotImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding ChromaticFocalShift.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <Border Background="#F0F0F0" IsVisible="{Binding ChromaticFocalShift.IsDisabled}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Requires multiple wavelengths."
                       FontSize="16" Foreground="#888"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Longitudinal Aberration" IsVisible="{Binding LongitudinalAberration.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <TextBlock Text="Pupil zones:" VerticalAlignment="Center" />
              <TextBox Text="{Binding LongitudinalAberration.NumZones, UpdateSourceTrigger=LostFocus}" Width="50" />
              <Button Content="Compute" Command="{Binding LongitudinalAberration.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding LongitudinalAberration.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="LongitudinalAberration" Width="90" FontSize="11" />
              <Button Content="Show Table" Click="LongitudinalAberrationShowTable_Click" Width="80" FontSize="11" />
              <Button Content="Close Tab" Click="CloseLongitudinalAberrationTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding LongitudinalAberration.PlotImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding LongitudinalAberration.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <Border Background="#F0F0F0" IsVisible="{Binding LongitudinalAberration.IsDisabled}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Not applicable for afocal systems."
                       FontSize="16" Foreground="#888"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Single Ray Trace" IsVisible="{Binding SingleRayTrace.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="6">
              <RadioButton Content="Field:" IsChecked="{Binding SingleRayTrace.UseFieldIndex}" GroupName="RayMode" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding SingleRayTrace.FieldOptions}"
                        SelectedIndex="{Binding SingleRayTrace.SelectedFieldIndex}"
                        IsEnabled="{Binding SingleRayTrace.UseFieldIndex}" Width="140" />
              <RadioButton Content="Hy:" GroupName="RayMode" VerticalAlignment="Center" />
              <TextBox Text="{Binding SingleRayTrace.Hy}" Width="50" IsEnabled="{Binding !SingleRayTrace.UseFieldIndex}" />
              <TextBlock Text="Px:" VerticalAlignment="Center" />
              <TextBox Text="{Binding SingleRayTrace.Px, UpdateSourceTrigger=LostFocus}" Width="50" />
              <TextBlock Text="Py:" VerticalAlignment="Center" />
              <TextBox Text="{Binding SingleRayTrace.Py, UpdateSourceTrigger=LostFocus}" Width="50" />
              <TextBlock Text="Wave:" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding SingleRayTrace.WaveOptions}"
                        SelectedIndex="{Binding SingleRayTrace.SelectedWaveIndex}" Width="160" />
              <Button Content="Trace" Command="{Binding SingleRayTrace.ComputeCommand}" Width="70" />
              <Button Content="Select All" Click="RayTraceSelectAll_Click" Width="70" FontSize="11" />
              <Button Content="Copy" Click="RayTraceCopy_Click" Width="50" FontSize="11" />
              <Button Content="Copy Table" Command="{Binding SingleRayTrace.CopyTableToClipboardCommand}" Width="85" FontSize="11" />
              <Button Content="Close Tab" Click="CloseSingleRayTraceTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Top" Margin="4,0,4,2">
              <TextBlock Text="{Binding SingleRayTrace.StatusText}" FontSize="11" Foreground="#555" />
            </StackPanel>
            <DataGrid x:Name="RayTraceGrid" ItemsSource="{Binding SingleRayTrace.Rows}" IsReadOnly="True"
                      AutoGenerateColumns="False" CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      GridLinesVisibility="All" FontSize="11" FontFamily="Consolas"
                      Margin="4" HeadersVisibility="Column"
                      SelectionMode="Extended" ClipboardCopyMode="IncludeHeader">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Surf" Binding="{Binding Surf}" Width="50" />
                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="140" />
                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="140" />
                <DataGridTextColumn Header="Z" Binding="{Binding Z}" Width="140" />
                <DataGridTextColumn Header="L" Binding="{Binding L}" Width="140" />
                <DataGridTextColumn Header="M" Binding="{Binding M}" Width="140" />
                <DataGridTextColumn Header="N" Binding="{Binding N}" Width="140" />
                <DataGridTextColumn Header="Ln" Binding="{Binding Ln}" Width="140" />
                <DataGridTextColumn Header="Mn" Binding="{Binding Mn}" Width="140" />
                <DataGridTextColumn Header="Nn" Binding="{Binding Nn}" Width="140" />
                <DataGridTextColumn Header="AOI" Binding="{Binding AOI}" Width="100" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="120" />
                <DataGridTextColumn Header="OPL" Binding="{Binding OPL}" Width="120" />
                <DataGridTextColumn Header="Cumul OPL" Binding="{Binding CumulOPL}" Width="140" />
                <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="80" />
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding SingleRayTrace.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Tracing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <!-- FFT PSF Tab (visible on demand via Analysis menu) -->
      <TabItem Header="FFT PSF" IsVisible="{Binding FftPsf.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <TextBlock Text="Grid:" VerticalAlignment="Center" />
              <ComboBox SelectedIndex="1" SelectionChanged="PsfGridChanged" Width="80">
                <ComboBoxItem Content="32" />
                <ComboBoxItem Content="64" />
                <ComboBoxItem Content="128" />
                <ComboBoxItem Content="256" />
                <ComboBoxItem Content="512" />
              </ComboBox>
              <TextBlock Text="Wavelength:" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding FftPsf.WavelengthOptions}"
                        SelectedIndex="{Binding FftPsf.SelectedWavelengthIndex}"
                        Width="160" />
              <Button Content="Compute" Command="{Binding FftPsf.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding FftPsf.ExportTextCommand}" Width="100" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="FftPsf" Width="90" FontSize="11" />
              <Button Content="Close Tab" Click="CloseFftPsfTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding FftPsf.PsfImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding FftPsf.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

      <!-- System Data Tab (visible on demand via Analysis menu) -->
      <TabItem Header="System Data" IsVisible="{Binding SystemData.IsVisible}">
        <Grid>
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
              <Button Content="Compute" Command="{Binding SystemData.ComputeCommand}" Width="80" />
              <Button Content="Export Text..." Command="{Binding SystemData.ExportTextCommand}" Width="100" />
              <Button Content="Copy Table" Command="{Binding SystemData.CopyTableToClipboardCommand}" Width="85" FontSize="11" />
              <Button Content="Export Image" Click="ExportImage_Click" Tag="SystemData" Width="90" FontSize="11" />
              <Button Content="Close Tab" Click="CloseSystemDataTab_Click" Width="70" FontSize="11" />
            </StackPanel>
            <Border Background="White" Margin="4">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding SystemData.PlotImage}"
                       Stretch="None"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
              </ScrollViewer>
            </Border>
          </DockPanel>
          <Border Background="#80FFFFFF" IsVisible="{Binding SystemData.IsBusy}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Computing..." FontSize="18" FontWeight="Bold" Foreground="#555"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </Grid>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
