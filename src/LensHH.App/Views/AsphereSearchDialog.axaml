<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LensHH.App.ViewModels"
        x:Class="LensHH.App.Views.AsphereSearchDialog"
        x:DataType="vm:AsphereSearchDialogViewModel"
        Title="Search Best Asphere Surface"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="950" Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="800" MinHeight="500">

  <DockPanel Margin="12">

    <!-- Bottom Buttons -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,6,0,0">
      <Button Grid.Column="0" Content="Start" Command="{Binding StartCommand}"
              IsEnabled="{Binding !IsRunning}" Width="90" Margin="0,0,8,0" FontWeight="SemiBold" />
      <Button Grid.Column="1" Content="Stop" Command="{Binding StopCommand}"
              IsEnabled="{Binding IsRunning}" Width="90" />
      <Button Grid.Column="3" Content="OK — Accept Results" Click="OK_Click" Width="180"
              IsEnabled="{Binding IsComplete}" FontWeight="SemiBold" Margin="0,0,8,0" />
      <Button Grid.Column="4" Content="Cancel — Revert" Click="Cancel_Click" Width="150" IsCancel="True" />
    </Grid>

    <!-- Help strip -->
    <Border DockPanel.Dock="Bottom" Background="#F5F5F0" BorderBrush="#CCC"
            BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="0,6,0,0">
      <TextBlock Text="{Binding HelpText}" FontSize="11" Foreground="#333"
                 TextWrapping="Wrap" MinHeight="28" />
    </Border>

    <!-- Settings -->
    <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="Auto,6,60,16,Auto,6,60,16,Auto,6,60,16,Auto,6,60,*"
            RowDefinitions="Auto,6,Auto">
        <!-- Row 0 -->
        <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Content="A4"
                  IsChecked="{Binding EnableA4}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center" />
        <CheckBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" Content="A6"
                  IsChecked="{Binding EnableA6}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center" />
        <CheckBox Grid.Row="0" Grid.Column="8" Grid.ColumnSpan="3" Content="A8"
                  IsChecked="{Binding EnableA8}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center" />

        <TextBlock Grid.Row="0" Grid.Column="12" Text="Top N:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="14" Text="{Binding TopN, UpdateSourceTrigger=LostFocus}"
                 IsEnabled="{Binding !IsRunning}" />

        <!-- Row 1 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="LM/Trial:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding LmIterationsPerTrial, UpdateSourceTrigger=LostFocus}"
                 IsEnabled="{Binding !IsRunning}" />

        <TextBlock Grid.Row="2" Grid.Column="4" Text="Final LM:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding FinalLmIterations, UpdateSourceTrigger=LostFocus}"
                 IsEnabled="{Binding !IsRunning}" />

        <TextBlock Grid.Row="2" Grid.Column="8" Text="Min Δ %:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="10" Text="{Binding MinImprovementPercent, UpdateSourceTrigger=LostFocus}"
                 IsEnabled="{Binding !IsRunning}" />

        <CheckBox Grid.Row="2" Grid.Column="12" Grid.ColumnSpan="5" Content="Reject if worse"
                  IsChecked="{Binding AcceptOnlyIfBetter}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Top" Background="#F5F5F5" CornerRadius="4"
            Padding="12,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="*,Auto,20,Auto" RowDefinitions="Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="14" />
        <TextBlock Grid.Column="1" Text="{Binding ElapsedText}" FontSize="13" />
        <TextBlock Grid.Column="3" FontSize="12" Foreground="Gray">
          <Run Text="Initial: " /><Run Text="{Binding InitialMeritText}" />
          <Run Text="   →   " />
          <Run Text="Final: " FontWeight="SemiBold" Foreground="Green" />
          <Run Text="{Binding FinalMeritText}" FontWeight="SemiBold" Foreground="Green" />
        </TextBlock>
      </Grid>
    </Border>

    <!-- Trials grid + log side by side -->
    <Grid ColumnDefinitions="*,8,*">
      <DataGrid Grid.Column="0" ItemsSource="{Binding TrialRows}"
                AutoGenerateColumns="False" CanUserSortColumns="False"
                GridLinesVisibility="All" IsReadOnly="True"
                FontSize="13" FontFamily="Consolas">
        <DataGrid.Columns>
          <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="50" />
          <DataGridTextColumn Header="Surface" Binding="{Binding SurfaceIndex}" Width="80" />
          <DataGridTextColumn Header="Post Merit" Binding="{Binding PostMerit}" Width="130" />
          <DataGridTextColumn Header="Δ %" Binding="{Binding ImprovementPercent}" Width="100" />
          <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
        </DataGrid.Columns>
      </DataGrid>

      <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" CornerRadius="3">
        <ScrollViewer>
          <TextBlock Text="{Binding LogText}" FontFamily="Consolas" FontSize="11"
                     Padding="6" TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </Grid>

  </DockPanel>
</Window>
