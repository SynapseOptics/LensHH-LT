<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LensHH.App.Views.TrialActivationDialog"
        Title="Start Free Trial"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="520" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockPanel Margin="20">

    <!-- Status message at bottom -->
    <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,10,0,0"
               TextWrapping="Wrap" FontSize="12" />

    <!-- Step 1: Email entry -->
    <StackPanel x:Name="Step1Panel" Spacing="10">
      <TextBlock Text="Enter your email to start a free 45-day trial:"
                 FontWeight="SemiBold" />
      <TextBlock Text="A verification code will be sent to your email."
                 Foreground="Gray" FontSize="12" />
      <TextBox x:Name="EmailBox" Watermark="you@example.com" FontSize="14" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
        <Button Content="Cancel" Click="Cancel_Click" Width="80" />
        <Button x:Name="SendCodeButton" Content="Send Code" Click="SendCode_Click"
                Width="120" Classes="accent" />
      </StackPanel>
      <Border BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Margin="0,12,0,0" />
      <TextBlock Text="Can't reach the activation server?"
                 Foreground="Gray" FontSize="12" Margin="0,8,0,0" />
      <Button x:Name="OfflineButton" Content="Activate offline from token file..."
              Click="Offline_Click" HorizontalAlignment="Left" />
    </StackPanel>

    <!-- Step 2: Code entry (hidden initially) -->
    <StackPanel x:Name="Step2Panel" Spacing="10" IsVisible="False">
      <TextBlock x:Name="CodePromptText"
                 Text="Enter the 6-digit code sent to your email:"
                 FontWeight="SemiBold" />
      <TextBox x:Name="CodeBox" Watermark="000000" MaxLength="6"
               FontFamily="Consolas,Courier New,monospace" FontSize="20"
               HorizontalContentAlignment="Center" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
        <Button Content="Back" Click="Back_Click" Width="80" />
        <Button x:Name="ResendButton" Content="Resend Code" Click="ResendCode_Click"
                Width="110" />
        <Button x:Name="ActivateButton" Content="Activate" Click="Activate_Click"
                Width="100" Classes="accent" />
      </StackPanel>
    </StackPanel>

    <!-- Step 3: Offline activation (hidden initially) -->
    <StackPanel x:Name="Step3Panel" Spacing="10" IsVisible="False">
      <TextBlock Text="Offline trial activation"
                 FontWeight="SemiBold" FontSize="14" />
      <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12"
                 Text="Email your machine ID below to support@synapseoptics.com. We will reply with a signed token file. Save it to disk, then browse to it here and click Activate." />

      <TextBlock Text="Your machine ID:" Margin="0,4,0,0" FontSize="12" />
      <TextBox x:Name="MachineIdBox" IsReadOnly="True"
               FontFamily="Consolas,Courier New,monospace" FontSize="11" />

      <TextBlock Text="Token file:" Margin="0,4,0,0" FontSize="12" />
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBox x:Name="TokenPathBox" IsReadOnly="True" Width="340"
                 Watermark="No file selected" />
        <Button x:Name="BrowseTokenButton" Content="Browse..."
                Click="BrowseToken_Click" Width="90" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
        <Button Content="Back" Click="BackFromOffline_Click" Width="80" />
        <Button x:Name="ActivateOfflineButton" Content="Activate"
                Click="ActivateOffline_Click" Width="100" Classes="accent"
                IsEnabled="False" />
      </StackPanel>
    </StackPanel>

  </DockPanel>
</Window>
