<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LensHH.App.ViewModels"
        x:Class="LensHH.App.Views.SplitElementDialog"
        x:DataType="vm:SplitElementDialogViewModel"
        Title="Split Element — Synthesis by Splitting"
        Icon="avares://LensHH.App/Assets/icon_256.png"
        Width="860" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="780" MinHeight="470">

  <DockPanel Margin="12">

    <!-- Bottom Buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
      <Button Content="OK — Accept Results" Click="OK_Click" Width="180"
              IsEnabled="{Binding IsComplete}" FontWeight="SemiBold" />
      <Button Content="Cancel — Revert" Click="Cancel_Click" Width="150" IsCancel="True" />
    </StackPanel>

    <!-- Help / description strip -->
    <Border DockPanel.Dock="Bottom" Background="#F5F5F0" BorderBrush="#CCC"
            BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="0,6,0,0">
      <TextBlock Text="{Binding HelpText}" FontSize="11" Foreground="#333"
                 TextWrapping="Wrap" MinHeight="28" />
    </Border>

    <!-- Settings -->
    <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1"
            CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
      <Grid ColumnDefinitions="Auto,6,60,16,Auto,6,60,16,Auto,6,60,*,Auto"
            RowDefinitions="Auto,6,Auto,6,Auto,6,Auto,6,Auto,6,Auto">
        <!-- Row 0 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Splits:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding MaxSplits, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Number of split operations to perform. Each split picks the element contributing most to residual aberration, replaces it with two thinner elements, and runs the glass + LM phases. Subsequent splits target the new worst element."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="0" Grid.Column="4" Text="Glass Trials:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="6" Text="{Binding GlassTrials, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Number of random (glass1, glass2) pairs tried for the two newly-split elements. Each trial runs a short LM (see LM/Trial) and the best pair is kept. Higher = better chance of finding a good glass combo."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="0" Grid.Column="8" Text="LM/Trial:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="10" Text="{Binding LmPerTrial, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Max Levenberg–Marquardt iterations used to rank each glass-pair trial. Keep small for fast ranking; Post LM does the deep refinement of the winner."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <!-- Row 1: Thickness constraints -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Min Glass:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding MinGlassThickness, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Lower bound (mm) for center thickness of the two new glass elements. Applied as ThicknessMin on the new surfaces and as the min for any CTG/EG penalty operands."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="2" Grid.Column="4" Text="Max Glass:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding MaxGlassThickness, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Upper bound (mm) for center thickness of the two new glass elements."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="2" Grid.Column="8" Text="Min Air:" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="10" Text="{Binding MinAirGap, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Minimum air-gap (mm) between the two split elements."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <!-- Row 2: More constraints + buttons -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Air:" VerticalAlignment="Center" />
        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding MaxAirGap, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Maximum air-gap (mm) between the two split elements. Keeps the pair from drifting apart unrealistically."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="4" Grid.Column="4" Text="Min Edge:" VerticalAlignment="Center" />
        <TextBox Grid.Row="4" Grid.Column="6" Text="{Binding MinEdgeThickness, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Minimum edge thickness (mm) for glass edges and air gaps at the rim. Used for the EG/EA operands added for the new surfaces (or widens an existing EG/EA span)."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="4" Grid.Column="8" Text="Post LM:" VerticalAlignment="Center" />
        <TextBox Grid.Row="4" Grid.Column="10" Text="{Binding PostSplitLm, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Max LM iterations for the final local optimization after the winning glass pair is chosen. This is where most of the quality comes from — set high enough for real convergence."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <!-- Row 3: Multistart settings -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Pre-Glass MS:" VerticalAlignment="Center" />
        <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding PreGlassTrials, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Multistart trials run before the glass-pair phase, with the two new elements still using their placeholder glass. Helps the geometry settle before committing to specific glasses."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="6" Grid.Column="4" Text="Post-Glass MS:" VerticalAlignment="Center" />
        <TextBox Grid.Row="6" Grid.Column="6" Text="{Binding PostGlassTrials, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Multistart trials run after the glass-pair phase, polishing the winning glass combo. Escapes local minima that deep LM alone would miss."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <TextBlock Grid.Row="6" Grid.Column="8" Text="MS Sigma:" VerticalAlignment="Center" />
        <TextBox Grid.Row="6" Grid.Column="10" Text="{Binding MsSigma, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding !IsRunning}"
                 Tag="Reset point for the Pre/Post-Glass multistart perturbation. Sigma returns here on every accepted improvement; on rejection it follows a triangle wave (shrinks for finer steps, then grows toward the cap to escape once it bottoms out). Default 0.001 — gentle starting refine pass after a split."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />


        <!-- Row 4: Options
             FreeAllGlasses checkbox removed from GUI in 1.0.45 — was added
             to work around the BFL-freeze bug that's now fixed in 1.0.44,
             so the regular three-phase flow handles all relevant cases
             with much better glass-pair efficiency. The setting still
             exists on SplitElementSettings + CLI / MCP for power users
             who want to force a single-phase global glass search. -->
        <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5" Content="Constrained only"
                  IsChecked="{Binding ConstrainedOnly}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center"
                  Tag="Restrict multistart randomization to variables that have at least one bound (min, max, or both). Truly unbounded variables keep their current value between trials."
                  PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                  GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <CheckBox Grid.Row="8" Grid.Column="6" Grid.ColumnSpan="5" Content="Reject if worse"
                  IsChecked="{Binding AcceptOnlyIfBetter}" IsEnabled="{Binding !IsRunning}" VerticalAlignment="Center"
                  Tag="If the final merit is worse than the starting merit, restore the original design and report the split as rejected. Default on. Turn off only when you want to commit a worse split for design-exploration purposes."
                  PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                  GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <!-- Row 5: Auto-skip-when-stalled (spans the same width as the multistart row above) -->
        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="9"
                   Text="Skip phase if no improvement for (s):" VerticalAlignment="Center" />
        <TextBox Grid.Row="10" Grid.Column="10" Text="{Binding SkipPhaseAfterNoImprovementSec, UpdateSourceTrigger=LostFocus}"
                 IsEnabled="{Binding !IsRunning}"
                 Tag="Auto-skip the active phase if BestMerit hasn't improved for this many seconds (default 180; 0 disables). Applies to the pre-glass and post-glass multistart phases only — glass trials always run to completion (they're already bounded by Glass Trials count) and can be skipped manually with the Next Phase button."
                 PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                 GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />

        <!-- Start / Next Phase / Stop — span all rows of the settings grid -->
        <StackPanel Grid.Row="0" Grid.RowSpan="11" Grid.Column="12" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" HorizontalAlignment="Right">
          <Button Content="Start" Command="{Binding StartCommand}" Width="70"
                  IsEnabled="{Binding !IsRunning}" FontWeight="SemiBold"
                  Tag="Begin the split-element run. Progress appears in the log panel; use Stop to cancel cleanly."
                  PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited" />
          <Button Content="Next Phase" Command="{Binding NextPhaseCommand}" Width="100"
                  IsEnabled="{Binding IsRunning}"
                  Tag="Skip the in-flight phase (pre-glass multistart, glass trials, or post-glass multistart) and continue to the next one. The run keeps the best result produced so far for the skipped phase."
                  PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited" />
          <Button Content="Stop" Command="{Binding StopCommand}" Width="70"
                  IsEnabled="{Binding IsRunning}"
                  Tag="Cancel the split-element run entirely. The design is restored to the best result produced so far."
                  PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Glass Catalogs + Status -->
    <Grid ColumnDefinitions="200,8,*" RowDefinitions="*">

      <!-- Glass catalog selection -->
      <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="6">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Glass Source" FontWeight="SemiBold" Margin="0,0,0,4" />
          <ComboBox DockPanel.Dock="Top" ItemsSource="{Binding GlassSourceOptions}"
                    SelectedIndex="{Binding SelectedGlassSourceIndex}"
                    IsEnabled="{Binding !IsRunning}" Margin="0,0,0,4"
                    Tag="Source of candidate glasses for the glass-pair trials. Pick a pre-filtered catalog (e.g. Crowns-only, Flints-only) or choose 'Loaded catalogs (select below)' to draw from the AGFs you tick."
                    PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                    GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />
          <CheckBox DockPanel.Dock="Top" Content="Only Preferred Glasses"
                    IsChecked="{Binding OnlyPreferred}" IsEnabled="{Binding !IsRunning}"
                    IsVisible="{Binding ShowLoadedCatalogs}" Margin="0,0,0,4"
                    Tag="When using loaded (unfiltered) catalogs, keep only glasses the catalog marks as preferred (Status ≤ 1). Filtered catalogs are already curated and ignore this flag."
                    PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited"
                    GotFocus="Help_GotFocus" LostFocus="Help_LostFocus" />
          <ScrollViewer IsVisible="{Binding ShowLoadedCatalogs}"
                        Tag="Tick every loaded catalog the glass-pair trials should draw from."
                        PointerEntered="Help_PointerEntered" PointerExited="Help_PointerExited">
            <ItemsControl ItemsSource="{Binding Catalogs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:CatalogCheckItem">
                  <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Status and log -->
      <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="6">
        <DockPanel>
          <!-- Status bar — left column flexes, right column hugs its
               content so long status / merit lines aren't truncated by
               the trial counter on the right. -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,6">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding PhaseText}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ElapsedText}" HorizontalAlignment="Right" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding StatusText}"
                       Foreground="Gray" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TrialText}"
                       HorizontalAlignment="Right" Foreground="Gray" Margin="8,0,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="0">
              <TextBlock.Text>
                <MultiBinding StringFormat="Merit: {0} -> {1}">
                  <Binding Path="InitialMeritText" />
                  <Binding Path="CurrentMeritText" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StalledText}"
                       HorizontalAlignment="Right" Foreground="#888" Margin="8,0,0,0" />
            <ProgressBar Grid.Row="3" Grid.ColumnSpan="2" Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent}" Height="6" Margin="0,4,0,0"
                         IsVisible="{Binding IsRunning}"
                         IsIndeterminate="{Binding ProgressIndeterminate}" />
          </Grid>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
            <Button Content="Copy Log" Command="{Binding CopyLogCommand}" Padding="8,2" FontSize="11" />
            <Button Content="Clear Log" Command="{Binding ClearLogCommand}" Padding="8,2" FontSize="11" />
          </StackPanel>
          <Separator DockPanel.Dock="Top" Margin="0,0,0,4" />
          <!-- Log -->
          <TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True"
                   FontFamily="Consolas,Courier New,monospace" FontSize="11"
                   TextWrapping="Wrap" />
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
